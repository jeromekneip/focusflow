<Window x:Class="FocusFlow.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocusFlow Settings"
        Width="460"
        SizeToContent="Height"
        MaxHeight="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        FontFamily="{StaticResource Font.Sans}">

    <Window.Resources>
        <!-- Section header: tracked-out muted caps -->
        <Style x:Key="SectionLabel" TargetType="TextBlock" BasedOn="{StaticResource TrackedCaps}">
            <Setter Property="FontSize" Value="{StaticResource Size.Micro}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <!-- Field row label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="FontSize" Value="{StaticResource Size.Label}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Themed scrollbar: thin (8px) low-contrast track + accent thumb.
             Matches the dusk aesthetic when the settings card content scrolls.
             RepeatButton parts are zeroed out so only the thumb is interactive. -->
        <Style x:Key="ScrollBarThumb.Dusk" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4"
                                Background="{StaticResource Brush.Control.Border}"
                                Opacity="0.72"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBar.Dusk" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="True"
                              Background="Transparent">
                            <!-- Faint track -->
                            <Border CornerRadius="4"
                                    Background="#0CFFFFFF"
                                    Margin="2,4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <!-- Zero-size so the track fills the full height. -->
                                    <RepeatButton Command="ScrollBar.LineUpCommand"
                                                  Width="0" Height="0"
                                                  Opacity="0"
                                                  Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand"
                                                  Width="0" Height="0"
                                                  Opacity="0"
                                                  Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb.Dusk}"
                                           Margin="1,0"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer that hosts the Dusk scrollbar. -->
        <Style x:Key="ScrollViewer.Dusk" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Style="{StaticResource ScrollBar.Dusk}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer surface now speaks the hero language: dusk gradient + warm radial
         glow + faint grain + rounded outer corners (was square CornerRadius=0). -->
    <Border CornerRadius="{StaticResource Radius.Lg}"
            Background="{StaticResource Brush.Dusk.Vertical}"
            BorderBrush="{StaticResource Brush.Hairline}"
            BorderThickness="1">
        <Grid>
            <!-- Decorative layers clipped to the rounded card via a CornerRadius
                 Border with ClipToBounds, so the glow + grain never bleed past
                 the rounded outer corners. -->
            <Border CornerRadius="{StaticResource Radius.Lg}" ClipToBounds="True">
                <Grid>
                    <!-- Faint off-center warm radial glow (gradient, not blur) -->
                    <Rectangle>
                        <Rectangle.Fill>
                            <RadialGradientBrush GradientOrigin="0.32,0.18" Center="0.32,0.18"
                                                 RadiusX="0.9" RadiusY="0.7">
                                <GradientStop Color="#3A5C3A2E" Offset="0"/>
                                <GradientStop Color="#1A2F2A3A" Offset="0.5"/>
                                <GradientStop Color="#00141220" Offset="1"/>
                            </RadialGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Faint tiled grain at the same ~4% effective level as the hero. -->
                    <Rectangle Opacity="1.0">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="pack://application:,,,/Assets/grain.png"
                                        TileMode="Tile"
                                        Viewport="0,0,128,128"
                                        ViewportUnits="Absolute"
                                        Stretch="None"/>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>

            <Grid Margin="28,24,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Serif title + close. The whole header row is the drag region
                     (MouseLeftButtonDown -> DragMove, mirroring MiniTimerWindow).
                     Background must be hit-testable for the drag, so the row gets
                     a Transparent background rather than the default null. -->
                <Grid Grid.Row="0" Margin="0,0,0,18"
                      Background="Transparent"
                      MouseLeftButtonDown="OnTitleBarDrag">
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Style="{StaticResource Display}"
                                   Text="Settings"
                                   FontSize="{StaticResource Size.Title}"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Shape your focus rhythm."
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Subtle ghost ✕. Reuses the Cancel path: IsCancel="True" so
                         Esc/click both route through OnCancel just like Cancel. -->
                    <Button x:Name="CloseButton"
                            Style="{StaticResource MiniButton}"
                            Content="&#x2715;"
                            FontSize="{StaticResource Size.Label}"
                            Width="28" Height="28"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            ToolTip="Close"
                            AutomationProperties.Name="Close"
                            IsCancel="True"
                            Click="OnCancel"/>
                </Grid>

                <!-- Scrollable body (guards against clipping); themed scrollbar (L4). -->
                <ScrollViewer Grid.Row="1"
                              Style="{StaticResource ScrollViewer.Dusk}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,6,0">
                    <StackPanel>

                        <!-- ===== PRESETS ===== -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="P R E S E T S"/>
                        <Border Height="1" Background="{StaticResource Brush.Hairline}" Margin="0,4,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="PomodoroButton" Style="{StaticResource SegmentButton}"
                                    Content="Pomodoro" Margin="0,0,8,0" Click="OnPreset"/>
                            <Button x:Name="DeepWorkButton" Style="{StaticResource SegmentButton}"
                                    Content="Deep Work" Margin="0,0,8,0" Click="OnPreset"/>
                            <Button x:Name="UltradianButton" Style="{StaticResource SegmentButton}"
                                    Content="Ultradian" Margin="0,0,8,0" Click="OnPreset"/>
                            <Button x:Name="TestButton" Style="{StaticResource SegmentButton}"
                                    Content="Test (QA)" Click="OnPreset"/>
                        </StackPanel>

                        <!-- ===== RHYTHM ===== -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="R H Y T H M" Margin="0,22,0,2"/>
                        <Border Height="1" Background="{StaticResource Brush.Hairline}" Margin="0,4,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="104"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="Focus (minutes)" Margin="0,6"/>
                            <TextBox x:Name="FocusBox" Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource FieldBox}" Margin="0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="Short break (minutes)" Margin="0,6"/>
                            <TextBox x:Name="ShortBox" Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource FieldBox}" Margin="0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="Long break (minutes)" Margin="0,6"/>
                            <TextBox x:Name="LongBox" Grid.Row="2" Grid.Column="1"
                                     Style="{StaticResource FieldBox}" Margin="0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}"
                                       Text="Blocks per long break" Margin="0,6"/>
                            <TextBox x:Name="BlocksBox" Grid.Row="3" Grid.Column="1"
                                     Style="{StaticResource FieldBox}" Margin="0,6"/>
                        </Grid>

                        <TextBlock x:Name="SecondScaleNote"
                                   Style="{StaticResource Caption}"
                                   Text="Test preset uses SECONDS, not minutes."
                                   Foreground="{StaticResource Brush.Accent.Awaiting}"
                                   FontSize="{StaticResource Size.Caption}"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>

                        <!-- ===== BEHAVIOR ===== -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="B E H A V I O R" Margin="0,22,0,2"/>
                        <Border Height="1" Background="{StaticResource Brush.Hairline}" Margin="0,4,0,8"/>
                        <CheckBox x:Name="SoundCheck" Style="{StaticResource ThemedCheckBox}"
                                  Content="Play chime on phase change"/>
                        <CheckBox x:Name="AutoStartCheck" Style="{StaticResource ThemedCheckBox}"
                                  Content="Start with Windows"/>
                        <CheckBox x:Name="OnTopCheck" Style="{StaticResource ThemedCheckBox}"
                                  Content="Mini timer always on top"/>
                        <CheckBox x:Name="OverlayCheck" Style="{StaticResource ThemedCheckBox}"
                                  Content="Full-screen break overlay"/>
                        <CheckBox x:Name="ConfirmReturnCheck" Style="{StaticResource ThemedCheckBox}"
                                  Content="Confirm I'm back at my desk before resuming focus"/>
                        <CheckBox x:Name="ReduceMotionCheck" Style="{StaticResource ThemedCheckBox}"
                                  Content="Reduce motion (suppress looping ring and pulse animations)"/>

                        <!-- ===== REFLECTION ===== -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="R E F L E C T I O N" Margin="0,22,0,2"/>
                        <Border Height="1" Background="{StaticResource Brush.Hairline}" Margin="0,4,0,12"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Shown on the break overlay."
                                   Margin="0,0,0,8"/>
                        <!-- Reflection box with watermark overlay (L5).
                             A transparent Grid lets the placeholder TextBlock sit
                             behind the actual TextBox; it hides when the box has text
                             via a DataTrigger in the code-behind (toggled on TextChanged). -->
                        <Grid>
                            <TextBox x:Name="ReflectionBox"
                                     Style="{StaticResource FieldBox}"
                                     Height="84"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto"/>
                            <TextBlock x:Name="ReflectionPlaceholder"
                                       Style="{StaticResource Caption}"
                                       Text="e.g. Are you still working on the right thing?"
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       Opacity="0.55"
                                       Margin="10,8,8,8"
                                       VerticalAlignment="Top"
                                       TextWrapping="Wrap"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Action row -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource GhostButton}"
                            Content="Cancel"
                            Padding="22,10"
                            Margin="0,0,10,0"
                            IsCancel="True"
                            Click="OnCancel"/>
                    <Button x:Name="SaveButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="Save"
                            FontSize="{StaticResource Size.Label}"
                            Padding="28,11"
                            Background="{StaticResource Brush.Accent.Focus}"
                            IsDefault="True"
                            Click="OnSave"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
