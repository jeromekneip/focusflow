<Window x:Class="FocusFlow.UI.MiniTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocusFlow"
        Width="208"
        MinHeight="104"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        SizeToContent="Height">
    <!-- Compact rounded card: translucent dark surface, hairline border, soft shadow.
         DropShadowEffect is allowed here (small element). -->
    <Border x:Name="RootBorder"
            CornerRadius="{StaticResource Radius.Lg}"
            Background="{StaticResource Brush.Surface.Translucent}"
            BorderBrush="{StaticResource Brush.Hairline}"
            BorderThickness="1"
            Margin="8"
            MouseLeftButtonDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="3" Opacity="0.45"/>
        </Border.Effect>
        <!-- Outer Grid lets the gear button sit in the top-right corner as an
             absolute overlay without disturbing the inner content layout. -->
        <Grid>
        <!-- Gear / settings button — top-right corner. Bumped to 26×26 (M5) so the
             hit area reads without hover; 6px offset keeps it clear of the drag
             zone. The Button handles MouseLeftButtonDown before it can bubble to
             RootBorder's OnDrag handler, so clicking the gear never starts a drag. -->
        <Button x:Name="SettingsButton"
                Style="{StaticResource MiniButton}"
                Width="26" Height="26"
                Padding="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,6,6,0"
                ToolTip="Settings"
                AutomationProperties.Name="Settings"
                TabIndex="2"
                Click="OnSettingsClick">
            <TextBlock Text="&#xE713;"
                       FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons"
                       FontSize="13"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Button>
        <!-- Inner content grid: 6px right padding reserves a non-drag gap next to
             the gear button so a near-miss on it does not start a window drag (M5). -->
        <Grid Margin="14,11,34,11">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- H1: cycle-position dots row -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- H3: first-run nudge caption -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Phase dot + tracked sans label.
                 AutomationProperties.Name on the StackPanel surfaces the clean
                 phase word to screen readers (H1, M2); the visual TrackOut spacing
                 is preserved on the TextBlock underneath. -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center"
                        AutomationProperties.Name="Phase">
                <Ellipse x:Name="PhaseDot"
                         Width="9" Height="9"
                         Fill="{StaticResource Brush.Text.Muted}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock x:Name="PhaseLabel"
                           Style="{StaticResource Label}"
                           Text="IDLE"
                           FontSize="{StaticResource Size.Micro}"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Idle"/>
            </StackPanel>

            <!-- H1: cycle-position dot row. Filled dots = completed focus blocks;
                 hollow dots = remaining blocks before the long break.
                 Dots are generated from code-behind; hidden when in Idle/break phases. -->
            <ItemsControl x:Name="CycleDotsPanel"
                          Grid.Row="1"
                          Margin="0,5,0,0"
                          Visibility="Collapsed"
                          AutomationProperties.Name="Cycle progress"
                          Focusable="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Tabular serif countdown -->
            <TextBlock x:Name="TimeLabel"
                       Grid.Row="2"
                       Style="{StaticResource Numeral}"
                       Text="00:00"
                       FontSize="{StaticResource Size.Title}"
                       Margin="0,1,0,0"/>

            <!-- H3: first-run nudge caption. Shown once at Idle until Start is pressed.
                 Warm muted tone; collapses after FirstRunCompleted is set. -->
            <TextBlock x:Name="FirstRunCaption"
                       Grid.Row="3"
                       Style="{StaticResource Caption}"
                       Text="Press Start when you're ready to focus."
                       Foreground="{StaticResource Brush.Text.Muted}"
                       Opacity="0.72"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>

            <!-- Control row. Buttons are visible AT REST (no hover needed). Which
                 buttons show is driven per AppPhase in code-behind:
                   Idle           -> StartButton (primary accent pill)
                   Running phases  -> PauseButton (Pause/Resume) + SkipButton
                   AwaitingReturn  -> PauseButton relabeled "I'm back" -->
            <Grid Grid.Row="4" Margin="0,9,0,0">
                <!-- Idle: single prominent Start. TabIndex=0 (primary action, M1). -->
                <Button x:Name="StartButton"
                        Style="{StaticResource MiniPrimaryButton}"
                        Content="Start"
                        Height="26"
                        HorizontalAlignment="Stretch"
                        Padding="0,0,0,0"
                        TabIndex="0"
                        Click="OnPauseClick"/>

                <!-- Running / AwaitingReturn: Pause/Resume (+ Skip when running).
                     Pause/Resume is the primary action -> TabIndex=0; Skip -> 1 (M1). -->
                <StackPanel x:Name="RunControls"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                    <Button x:Name="PauseButton"
                            Style="{StaticResource MiniPrimaryButton}"
                            Content="Pause"
                            Width="92" Height="26"
                            Padding="0,0,0,0"
                            TabIndex="0"
                            Click="OnPauseClick"
                            Margin="0,0,8,0"/>
                    <Button x:Name="SkipButton"
                            Style="{StaticResource MiniButton}"
                            Content="Skip"
                            Width="60" Height="26"
                            Padding="0,0,0,0"
                            TabIndex="1"
                            Click="OnSkipClick"/>
                </StackPanel>
            </Grid>
        </Grid>
        </Grid><!-- /outer overlay grid -->
    </Border>
</Window>
